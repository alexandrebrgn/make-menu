generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int     @id @default(autoincrement())
  firstname String
  lastname  String
  foods     Food[] 
}

model Food {
  id        Int      @id @default(autoincrement())
  name      String
  quantity  Float
  unit      String
  expiresAt DateTime?
  category  String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

